# ── Supabase (Phase 3) ────────────────────────────────────────────────
# Copier ce fichier en `.env` et renseigner les valeurs de ton projet Supabase
# (Project Settings → API). Tant que ces variables sont vides, l'app fonctionne
# en mode JSON local (fichiers src/data/*.json).

# Client navigateur (préfixe VITE_ obligatoire pour être exposé au front) :
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Scripts serveur (seed / scraping) — NE JAMAIS committer la vraie valeur :
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Base commune « colonne vertébrale » (Dossier Startup) ─────────────
# Projet Supabase SÉPARÉ, partagé entre les 3 apps. Détient l'entité startup
# et ses documents (schéma `core`). Quand un document est uploadé, il alimente
# cette base (voir src/services/startup-documents.ts).
# Projet : « INSKIP Core - Dossier Startup ».
VITE_CORE_SUPABASE_URL=
VITE_CORE_SUPABASE_ANON_KEY=
